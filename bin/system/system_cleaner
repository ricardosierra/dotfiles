#!/usr/bin/env bash
#################################################################
# system_cleaner — atualiza Ubuntu/Debian + limpa caches de RAM #
# Autor original: Matheus Ferreira Cardoso (M-Unix)             #
# ROOT_REQUIRED. PT-BR.                                         #
#################################################################

command -v apt-get >/dev/null 2>&1 || {
  echo "system_cleaner: precisa de apt-get (Ubuntu/Debian)"
  exit 1
}
command -v dialog >/dev/null 2>&1 || {
  echo "Faltando: dialog (apt install dialog)"
  exit 1
}

dialog --title 'Vamos atualizar/Otimizar' \
       --msgbox 'Bem vindo ao cleaner.' 6 40

t=0
while [ $t -lt 100 ]; do
  t=$((t + 1))
  echo $t
  sleep .1
done | dialog --gauge "Otimizando Aguarde........." 6 75

sudo apt-get update -y               # atualizar lista de pacotes
sudo apt-get upgrade -y              # efetuar atualização
sudo apt-get -y -f install           # corrigir dependências
sudo apt-get autoremove -y           # remover pacotes órfãos
sudo apt-get autoclean -y            # remover pacotes antigos
sudo apt-get clean -y                # limpar cache

echo "##############################################################"
echo "######################### AGUARDE ############################"
echo "##############################################################"
sleep 4

# Limpar cache de RAM
MEM1=$(free | awk '/Mem:/ {print int(100*$3/$2)}')
free -m
echo "##########################################################################"
echo "Memória RAM usada antes da limpeza: $MEM1%"
echo "##########################################################################"
echo "LIMPANDO MEMORIA --- RAM ---"
sleep 3
sync
sudo tee /proc/sys/vm/drop_caches <<< 3 >/dev/null
echo "LIMPANDO MEMORIA SWAP..."
sleep 4
sudo swapoff -a
sudo swapon -a
echo "##########################################################################"
MEM2=$(free | awk '/Mem:/ {print int(100*$3/$2)}')
free -m
echo "##########################################################################"
echo "Uso de memória RAM após a limpeza: $MEM2% (economia: $((MEM1 - MEM2))%)"
echo "##########################################################################"

dialog --title 'Aguarde' --sleep 5 \
       --infobox '\nFinalizando em 5 segundos...' 0 0
