#!/usr/bin/env bash
#
# procura-recursiva — busca por palavra-chave em todos os PDFs do diretório atual
# Autor original: Marco Carvalho de Oliveira <demoncyber@gmail.com>
# Colméia — Grupo de Pesquisa em Software Livre
#

command -v pdftotext >/dev/null 2>&1 || {
  echo "Faltando: pdftotext (instale com: brew install poppler / apt install poppler-utils)"
  exit 1
}

if [ -z "$1" ]; then
  echo "Uso: search-in-pdf <palavra>"
  exit 1
fi

OLDIFS="$IFS"
IFS=$'\n' # separador por quebra de linha (resolve nomes com espaços)

MYTMP="/tmp/procura-recursiva"
# pasta utilizada pelo programa

rm -rf "$MYTMP"
mkdir -p "$MYTMP"

for files_pdf in $(find . -type f -iname '*.pdf'); do
  LOC_FILE="$files_pdf"
  NAME_FILE="$(basename "$files_pdf")"
  FIND_FILE="$MYTMP/$NAME_FILE.txt"

  pdftotext "$LOC_FILE" "$FIND_FILE" 2>/dev/null

  if grep -q "$1" "$FIND_FILE" 2>/dev/null; then
    echo "Expressão encontrada no arquivo $NAME_FILE"
  fi
done

IFS="$OLDIFS"
