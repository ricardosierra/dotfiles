#!/usr/bin/env bash
# tempo — mostra clima atual via wttr.in
# Uso: tempo [cidade]  (default: Piracicaba)
#
# wttr.in suporta cidades em qualquer idioma:
#   tempo "São Paulo"
#   tempo Tokyo
#   tempo "New York"

command -v curl >/dev/null 2>&1 || {
  echo "Faltando: curl"
  exit 1
}

city="${1:-Piracicaba}"
curl -s "wttr.in/${city// /%20}?format=3"
