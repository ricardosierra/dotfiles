#!/bin/sh
# Linta shell scripts modificados no push. Instale com: bin/dotfiles-install-hooks

EMPTY_TREE="4b825dc642cb6eb9a060e54bf8d69288fbee4904"
ZERO_SHA="0000000000000000000000000000000000000000"

if ! command -v shellcheck >/dev/null 2>&1; then
  echo "aviso: shellcheck não instalado — lint ignorado." >&2
  exit 0
fi

failed=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # Branch sendo deletado remotamente — nada a lintar
  [ "$local_sha" = "$ZERO_SHA" ] && continue

  # Branch novo sem histórico remoto → compara contra empty-tree
  if [ "$remote_sha" = "$ZERO_SHA" ]; then
    base="$EMPTY_TREE"
  else
    base="$remote_sha"
  fi

  files=$(git diff --name-only "$base" "$local_sha" 2>/dev/null)

  for f in $files; do
    # Excluir submódulos vendor
    case "$f" in
      link/.oh-my-zsh/*|link/.tmux/plugins/*) continue ;;
    esac

    # Arquivo deve existir no FS (pular deletados)
    [ -f "$f" ] || continue

    # Incluir se extensão .sh ou shebang shell
    case "$f" in
      *.sh) ;;
      *) head -1 "$f" 2>/dev/null | grep -qE '^#!.*(bash|sh|zsh)' || continue ;;
    esac

    if shellcheck -x --severity=warning "$f"; then
      echo "  ✓ $f"
    else
      failed=1
    fi
  done
done

if [ "$failed" -ne 0 ]; then
  echo ""
  echo "push abortado: corrija os erros acima e tente novamente." >&2
  exit 1
fi
