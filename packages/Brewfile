brew "p7zip"              # 7z, zip, rar (read), iso, dmg
brew "pandoc"             # converte praticamente qualquer formato
brew "poppler"            # pdftotext/pdfimages/pdfinfo
brew "qpdf"               # inspeção/manipulação de PDF
