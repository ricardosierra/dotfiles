# Brewfile — pacotes macOS gerenciados via Homebrew Bundle.
#
# Uso:
#   brew bundle --file=packages/Brewfile          # instala tudo que falta
#   brew bundle check --file=packages/Brewfile    # lista o que falta
#   brew bundle cleanup --file=packages/Brewfile  # mostra o que está instalado e não está aqui
#   brew bundle dump --file=packages/Brewfile     # gera Brewfile do estado atual
#
# Conteúdo extraído de init/30_osx_homebrew_recipes.sh e
# init/30_osx_homebrew_casks.sh (preservados como fallback até migração final).

# =============================================================================
# Formulae (CLI tools)
# =============================================================================

